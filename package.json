{
  "name": "friday-sandbox",
  "private": true,
  "description": "A pnpm + Turborepo monorepo that ships the @friday-sandbox/* packages.",
  "keywords": [
    "monorepo",
    "turborepo",
    "react",
    "design-system",
    "tailwindcss",
    "react-aria"
  ],
  "homepage": "https://github.com/next-friday/friday-sandbox#readme",
  "bugs": {
    "url": "https://github.com/next-friday/friday-sandbox/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/next-friday/friday-sandbox.git"
  },
  "license": "MIT",
  "author": {
    "name": "Next Friday",
    "url": "https://github.com/next-friday"
  },
  "scripts": {
    "build": "turbo run build",
    "build:docs": "turbo run build --filter=@friday-sandbox/docs",
    "build:storybook": "turbo run build:storybook",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "clean": "turbo run clean",
    "depcruise": "depcruise packages",
    "dev": "turbo run dev dev:storybook",
    "dev:docs": "turbo run dev --filter=@friday-sandbox/docs",
    "dev:storybook": "turbo run dev:storybook",
    "format": "prettier --write \"**/*.{ts,tsx,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,css}\"",
    "gen": "turbo gen",
    "knip": "knip",
    "lint": "turbo run lint",
    "lint:md": "markdownlint-cli2",
    "lint:symmetry": "bash scripts/check-component-symmetry.sh",
    "prepare": "husky",
    "sort": "sort-package-json \"package.json\" \"packages/*/package.json\" \"apps/*/package.json\"",
    "sort:check": "sort-package-json --check \"package.json\" \"packages/*/package.json\" \"apps/*/package.json\"",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@friday-sandbox/typescript-config": "workspace:*",
    "@turbo/gen": "^2.9.18",
    "@types/node": "^22.15.3",
    "dependency-cruiser": "^18.0.0",
    "husky": "^9.1.7",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sort-package-json": "^4.0.0",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=22.10.0",
    "pnpm": ">=9.0.0"
  }
}
