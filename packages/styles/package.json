{
  "name": "@friday-sandbox/styles",
  "version": "1.0.0",
  "description": "Design tokens, Tailwind CSS v4 layers, and component variant maps for @friday-sandbox/react.",
  "keywords": [
    "css",
    "tailwindcss",
    "design-tokens",
    "design-system"
  ],
  "homepage": "https://github.com/next-friday/friday-sandbox/tree/main/packages/styles#readme",
  "bugs": {
    "url": "https://github.com/next-friday/friday-sandbox/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/next-friday/friday-sandbox.git",
    "directory": "packages/styles"
  },
  "license": "MIT",
  "author": {
    "name": "Next Friday",
    "url": "https://github.com/next-friday"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "style": "./index.css",
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./css": {
      "style": "./index.css",
      "default": "./index.css"
    },
    "./components/*": {
      "types": "./src/components/*/index.ts",
      "import": "./src/components/*/index.ts",
      "default": "./src/components/*/index.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node --experimental-strip-types scripts/build.ts",
    "clean": "rm -rf dist",
    "lint": "eslint . --max-warnings 0",
    "measure-size": "node --experimental-strip-types scripts/measure-bundle-size.ts",
    "prepack": "clean-package",
    "postpack": "clean-package restore",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@friday-sandbox/eslint-config": "workspace:*",
    "@friday-sandbox/typescript-config": "workspace:*",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^22.15.3",
    "clean-package": "^2.2.0",
    "eslint": "^9.39.4",
    "rollup": "^4.52.4",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
