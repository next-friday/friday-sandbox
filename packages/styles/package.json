{
  "name": "@friday-sandbox/styles",
  "version": "1.0.0",
  "description": "Design tokens and Tailwind CSS v4 layers consumed by @friday-sandbox/react.",
  "keywords": [
    "css",
    "tailwindcss",
    "design-tokens",
    "design-system"
  ],
  "homepage": "https://github.com/next-friday/friday-sandbox/tree/main/packages/styles#readme",
  "bugs": {
    "url": "https://github.com/next-friday/friday-sandbox/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/next-friday/friday-sandbox.git",
    "directory": "packages/styles"
  },
  "license": "MIT",
  "author": {
    "name": "Next Friday",
    "url": "https://github.com/next-friday"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "style": "./index.css",
      "default": "./index.css"
    },
    "./css": {
      "style": "./index.css",
      "default": "./index.css"
    },
    "./schema": "./theme-spec.schema.json",
    "./tokens": "./tokens/default.spec.json",
    "./template": {
      "style": "./src/theme-template.css",
      "default": "./src/theme-template.css"
    },
    "./compat": {
      "style": "./src/theme/compat.css",
      "default": "./src/theme/compat.css"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "index.css",
    "theme-spec.schema.json",
    "tokens",
    "design.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node --experimental-strip-types scripts/codegen.ts && node --experimental-strip-types scripts/validate.ts && tailwindcss --input index.css --output dist/index.css --minify",
    "clean": "rm -rf dist",
    "codegen": "node --experimental-strip-types scripts/codegen.ts",
    "lint": "eslint . --max-warnings 0",
    "prepack": "clean-package",
    "postpack": "clean-package restore",
    "test": "node --experimental-strip-types --test \"scripts/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "validate": "node --experimental-strip-types scripts/validate.ts"
  },
  "devDependencies": {
    "@friday-sandbox/eslint-config": "workspace:*",
    "@friday-sandbox/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.3.1",
    "@types/apca-w3": "^0.1.3",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.15.3",
    "ajv": "^8.20.0",
    "apca-w3": "^0.1.9",
    "clean-package": "^2.2.0",
    "culori": "^4.0.2",
    "eslint": "^9.39.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
