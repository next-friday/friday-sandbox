{
  "name": "@friday-sandbox/react",
  "version": "1.0.0",
  "description": "Accessible React UI components built on react-aria-components and Tailwind CSS v4.",
  "keywords": [
    "react",
    "react-aria",
    "ui",
    "components",
    "design-system",
    "tailwindcss",
    "accessible",
    "a11y"
  ],
  "homepage": "https://github.com/next-friday/friday-sandbox/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/next-friday/friday-sandbox/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/next-friday/friday-sandbox.git",
    "directory": "packages/react"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Next Friday",
    "url": "https://github.com/next-friday"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*/index.ts",
      "import": "./src/*/index.ts",
      "default": "./src/*/index.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:storybook": "storybook build",
    "check-types": "tsc --noEmit",
    "chromatic": "chromatic --build-script-name=build:storybook --exit-zero-on-changes",
    "dev:storybook": "storybook dev -p 6006",
    "doc:check": "storybook build --quiet",
    "lint": "eslint . --max-warnings 0",
    "prepack": "clean-package",
    "postpack": "clean-package restore",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "radix-ui": "^1.6.0",
    "react-aria-components": "^1.18.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@friday-sandbox/eslint-config": "workspace:*",
    "@friday-sandbox/styles": "workspace:*",
    "@friday-sandbox/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "chromatic": "^17.5.0",
    "clean-package": "^2.2.0",
    "eslint": "^9.39.1",
    "playwright": "^1.61.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "tsdown": "^0.22.0",
    "typescript": "5.9.2",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@friday-sandbox/styles": "workspace:^",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
