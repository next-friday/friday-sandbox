set -euo pipefail

# Gates are scoped by `turbo --affected`, which derives the touched packages from
# the pushed git range (TURBO_SCM_BASE..TURBO_SCM_HEAD) + the dependency graph +
# turbo's global inputs (lockfile, root package.json, turbo.json). 0 affected
# tasks ⇒ no package/dependency changed (e.g. a docs-only push) ⇒ code & graph
# gates are skipped. Nothing is hardcoded by file type, and CI re-runs the full
# suite regardless.

ZERO="0000000000000000000000000000000000000000"
TURBO_TASKS=(lint typecheck build test build:storybook)

secret_scan() {
  if command -v gitleaks >/dev/null 2>&1; then
    gitleaks git --no-banner --redact
  else
    echo "gitleaks not installed — skipping secret scan (brew install gitleaks)"
  fi
}

# Cheap, repo-wide, and the only gates that cover non-package files
# (.md, .yml, .json) → always run, even on a docs-only push.
always_gates() {
  secret_scan
  if command -v actionlint >/dev/null 2>&1; then
    actionlint
  else
    echo "actionlint not installed — skipping workflow lint (brew install actionlint)"
  fi
  pnpm -w format:check
  pnpm -w sort:check
  pnpm -w lint:prose
}

# Graph-wide, no per-package turbo task → run only when a package/dep changed.
graph_gates() {
  pnpm -w knip
  pnpm -w depcruise
  pnpm audit --audit-level high
}

run_full() {
  pnpm exec turbo run "${TURBO_TASKS[@]}"
  graph_gates
}

run_scoped() {
  TURBO_SCM_BASE="$1" TURBO_SCM_HEAD="$2" pnpm exec turbo run "${TURBO_TASKS[@]}" --affected
  graph_gates
}

# Affected turbo task count in BASE..HEAD; empty on any turbo/jq failure so the
# caller can fall back to the full suite.
affected_count() {
  TURBO_SCM_BASE="$1" TURBO_SCM_HEAD="$2" \
    pnpm exec turbo run "${TURBO_TASKS[@]}" --affected --dry=json 2>/dev/null | jq '.tasks | length'
}

# git feeds the refs being pushed on stdin:
#   "<local_ref> <local_oid> <remote_ref> <remote_oid>"
base=""
head=""
refs=0
while read -r _local_ref local_oid _remote_ref remote_oid; do
  if [[ -z "${local_oid:-}" || "$local_oid" == "$ZERO" ]]; then
    continue # nothing / branch deletion
  fi
  refs=$((refs + 1))
  if [[ "$remote_oid" == "$ZERO" ]]; then # new branch on the remote
    remote_oid=$(git merge-base "$local_oid" origin/main 2>/dev/null || true)
  fi
  base="$remote_oid"
  head="$local_oid"
done

if [[ "$refs" -eq 0 ]]; then
  exit 0 # delete-only push — nothing to gate
fi

always_gates

# No single clean range (multiple refs / unknown base), or no jq to read turbo's
# plan → gate everything.
if [[ "$refs" -gt 1 || -z "$base" || -z "$head" ]] || ! command -v jq >/dev/null 2>&1; then
  run_full
  exit 0
fi

count=$(affected_count "$base" "$head") || count=""
if [[ -z "$count" ]]; then
  echo "pre-push: could not resolve the affected set — running full gates."
  run_full
elif [[ "$count" -gt 0 ]]; then
  echo "pre-push: $count affected task(s) in ${base}..${head} — running scoped gates."
  run_scoped "$base" "$head"
else
  echo "pre-push: no affected packages in ${base}..${head} — code & graph gates skipped (CI runs full)."
fi
