{
  "name": "@friday-sandbox/docs",
  "version": "0.0.0",
  "private": true,
  "description": "Documentation website for the @friday-sandbox design system.",
  "license": "MIT",
  "author": {
    "name": "Next Friday",
    "url": "https://github.com/next-friday"
  },
  "type": "module",
  "scripts": {
    "build": "next build",
    "clean": "rm -rf .next .source .turbo",
    "dev": "next dev",
    "postinstall": "fumadocs-mdx",
    "lint": "fumadocs-mdx && eslint . --max-warnings 0",
    "start": "next start",
    "typecheck": "fumadocs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "@friday-sandbox/react": "workspace:*",
    "@friday-sandbox/styles": "workspace:*",
    "fumadocs-core": "^16.10.6",
    "fumadocs-mdx": "^15.0.13",
    "fumadocs-ui": "^16.10.6",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@friday-sandbox/eslint-config": "workspace:*",
    "@friday-sandbox/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.6.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.10.0"
  }
}
