@layer components {
  .fri-{{ kebabCase name }} {
    --{{ kebabCase name }}-h: calc(var(--fri-spacing-xs) * var(--_{{ kebabCase name }}-n));
    --{{ kebabCase name }}-px: calc(var(--{{ kebabCase name }}-h) / 2 - var(--fri-spacing-xs));

    @apply relative inline-flex h-(--{{ kebabCase name }}-h) w-fit shrink-0 cursor-pointer items-center justify-center gap-sm rounded-sm border-(length:--fri-border-width) border-solid border-transparent bg-primary px-(--{{ kebabCase name }}-px) whitespace-nowrap text-primary-foreground transition-base outline-none select-none;
  }

  :where(.fri-{{ kebabCase name }}) {
    --_{{ kebabCase name }}-n: 10;
    @apply text-label-md;
  }
  .fri-{{ kebabCase name }}-xs {
    --_{{ kebabCase name }}-n: 7;
    @apply text-label-xs;
  }
  .fri-{{ kebabCase name }}-sm {
    --_{{ kebabCase name }}-n: 8;
    @apply text-label-sm;
  }
  .fri-{{ kebabCase name }}-md {
    --_{{ kebabCase name }}-n: 10;
    @apply text-label-md;
  }
  .fri-{{ kebabCase name }}-lg {
    --_{{ kebabCase name }}-n: 11;
    @apply text-label-lg;
  }
  .fri-{{ kebabCase name }}-xl {
    --_{{ kebabCase name }}-n: 12;
    @apply text-label-xl;
  }

  .fri-{{ kebabCase name }}[data-disabled],
  .fri-{{ kebabCase name }}:disabled,
  .fri-{{ kebabCase name }}[aria-disabled="true"] {
    @apply status-disabled;
  }

  .fri-{{ kebabCase name }}[data-focus-visible],
  .fri-{{ kebabCase name }}:focus-visible {
    @apply focus-ring;
  }
}
