@layer components {
  .fri-{{ kebabCase name }} {
    --{{ kebabCase name }}-h: calc(
      var(--fri-spacing-xsmall) * var(--{{ kebabCase name }}-units)
    );
    --{{ kebabCase name }}-px: calc(
      var(--{{ kebabCase name }}-h) / 2 - var(--fri-spacing-xsmall)
    );

    @apply relative inline-flex h-(--{{ kebabCase name }}-h) w-fit shrink-0 cursor-pointer items-center justify-center gap-small rounded-sm border-(length:--fri-border-width) border-solid border-transparent bg-primary px-(--{{ kebabCase name }}-px) whitespace-nowrap text-primary-foreground transition-base outline-none select-none;
  }

  :where(.fri-{{ kebabCase name }}) {
    --{{ kebabCase name }}-units: 10;
    @apply text-label-medium;
  }

  .fri-{{ kebabCase name }}-xs {
    --{{ kebabCase name }}-units: 7;
    @apply text-label-xsmall;
  }

  .fri-{{ kebabCase name }}-sm {
    --{{ kebabCase name }}-units: 8;
    @apply text-label-small;
  }

  .fri-{{ kebabCase name }}-md {
    --{{ kebabCase name }}-units: 10;
    @apply text-label-medium;
  }

  .fri-{{ kebabCase name }}-lg {
    --{{ kebabCase name }}-units: 11;
    @apply text-label-large;
  }

  .fri-{{ kebabCase name }}-xl {
    --{{ kebabCase name }}-units: 12;
    @apply text-label-xlarge;
  }

  .fri-{{ kebabCase name }}[data-disabled],
  .fri-{{ kebabCase name }}:disabled,
  .fri-{{ kebabCase name }}[aria-disabled="true"] {
    @apply status-disabled;
  }

  .fri-{{ kebabCase name }}[data-focus-visible],
  .fri-{{ kebabCase name }}:focus-visible {
    @apply focus-ring;
  }

  {{!-- Add fri-{{ kebabCase name }}-<color> and -<variant> rules for the ladder —
     one per role and variant, wiring the --fri-<role> slots; see button.css. --}}
}
